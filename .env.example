# Public Firebase web app config for Vite.
# Create a Firebase web app in Firebase Console and copy these values.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin credentials for serverless API routes.
# Use a service account key and keep these values only in local/Vercel env vars.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY=your_service_account_private_key

# Existing enquiry email setup.
RESEND_API_KEY=your_resend_api_key
BELTER_ENQUIRY_TO=belterinvestmentsltd@gmail.com
BELTER_FROM_EMAIL=Belter Enquiries <hello@belterinvestments.com>
